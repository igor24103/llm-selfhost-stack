# Domain for SSL certificate
DOMAIN=ai.yourdomain.com

# Open WebUI secret key (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=change-me-in-production

# Notification webhook (optional, for monitoring alerts)
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# GPU device IDs (comma-separated, or "all")
NVIDIA_VISIBLE_DEVICES=all
